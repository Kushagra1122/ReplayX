# ReplayX root runtime configuration
#
# Live Codex worker execution uses your existing Codex/OpenAI authentication on
# this machine. This repo does not read OPENAI_API_KEY directly.

# Optional model override for Codex SDK worker runs.
REPLAYX_CODEX_MODEL=gpt-5-codex

# Worker toggles. Set to 0 to disable live worker execution and rely on local
# fallback / replay-safe behavior.
REPLAYX_USE_CODEX_REPRO_WORKER=1
REPLAYX_USE_CODEX_DIAGNOSIS_WORKERS=1
REPLAYX_USE_CODEX_FIX_WORKERS=1

# Worker timeouts in milliseconds.
REPLAYX_CODEX_REPRO_TIMEOUT_MS=30000
REPLAYX_CODEX_DIAGNOSIS_TIMEOUT_MS=45000
REPLAYX_CODEX_FIX_TIMEOUT_MS=60000
